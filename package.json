{
  "name": "snapseeker",
  "version": "1.0.0",
  "description": "Desktop OCR search utility for screenshots",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.zubulika.snapseeker",
    "productName": "SnapSeeker",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "zubulika",
      "repo": "SnapSeeker"
    }
  },
  "author": "zubulika",
  "license": "ISC",
  "dependencies": {
    "electron-updater": "^6.8.9",
    "tesseract.js": "^5.1.0"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^26.15.3"
  }
}
